+  /**
+   * Load the sitemap type belonging to a domain.
+   *
+   * The domain is resolved via the sitemap_domain third party setting rather
+   * than the entity ID, as the sitemap type ID may be a shortened version of
+   * the domain ID.
+   *
+   * @param \Drupal\domain\DomainInterface $domain
+   *   The domain to load the sitemap type for.
+   *
+   * @return \Drupal\simple_sitemap\Entity\SimpleSitemapTypeInterface|null
+   *   The sitemap type or NULL if none exists for this domain.
+   */
+  public function loadSitemapType(DomainInterface $domain): ?SimpleSitemapTypeInterface {
+    $type_storage = $this->entityTypeManager->getStorage('simple_sitemap_type');
+    $ids = $type_storage->getQuery()
+      ->condition('third_party_settings.domain_simple_sitemap.sitemap_domain', $domain->id())
+      ->execute();
+    if ($ids) {
+      return $type_storage->load(reset($ids));
+    }
+    // Fall back to the legacy behavior of the sitemap type ID matching the
+    // domain ID.
+    $sitemap_type = $type_storage->load($domain->id());
+    return $sitemap_type instanceof SimpleSitemapTypeInterface ? $sitemap_type : NULL;
+  }
+
+  /**
+   * Generate a sitemap/sitemap type ID for a domain.
+   *
+   * Sitemap IDs are limited to EntityTypeInterface::ID_MAX_LENGTH (32)
+   * characters because the simple_sitemap table stores them in a varchar(32)
+   * column. Domain machine names can be longer, so IDs exceeding the limit
+   * are truncated and suffixed with a hash to keep them unique.
+   *
+   * @param \Drupal\domain\DomainInterface $domain
+   *   The domain to generate the sitemap ID for.
+   *
+   * @return string
+   *   A sitemap ID no longer than 32 characters.
+   */
+  public function generateSitemapId(DomainInterface $domain): string {
+    $id = $domain->id();
+    if (strlen($id) <= EntityTypeInterface::ID_MAX_LENGTH) {
+      return $id;
+    }
+    $hash = substr(md5($id), 0, 6);
+    return substr($id, 0, EntityTypeInterface::ID_MAX_LENGTH - 7) . '_' . $hash;
+  }
+
