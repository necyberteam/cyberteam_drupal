{#
/**
 * @file
 * Default theme implementation for contributors block.
 *
 * Available variables:
 * - items: Array of person data with uid, name, and photo_url.
 * - empty_message: Message to show when no items found.
 * - scrollable: Whether to constrain height with overflow scroll (default true).
 */
#}

<style>
  .people-grid-block svg,
  .people-grid-block .profile-photo {
    height: 70px;
    width: auto;
  }
  .people-grid-block.people-grid-block--scrollable {
    max-height: 205px;
    overflow: auto;
  }
  .people-grid-block .rounded-custom {
    border-radius: 1rem 0 1rem 0;
  }
  .people-grid-block .people-grid-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
<div class="people-grid-block{{ block_class ? ' ' ~ block_class }}{{ scrollable is not same as(false) ? ' people-grid-block--scrollable' }}">
  {% if items %}
    <ul class="people-grid-list">
      {% for item in items %}
        <li class="people-grid-item text-center">
          <a href="/community-persona/{{ item.uid }}" class="people-grid-link">
            <div class="people-grid-photo">
              {% if item.photo_url %}
                <img src="{{ item.photo_url }}" alt="{{ item.name }}" class="profile-photo rounded-custom" />
              {% else %}
                <img src="modules/custom/access/modules/cssn/images/profile.gif" alt="{{ item.name }}" class="profile-photo rounded-custom" />
              {% endif %}
            </div>
            <div class="people-grid-name">{{ item.name }}</div>
          </a>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>{{ empty_message|default('No people found.'|t) }}</p>
  {% endif %}
</div>
