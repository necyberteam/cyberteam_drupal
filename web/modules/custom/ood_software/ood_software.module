<?php

/**
 * @file
 */

use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\EntityTypeInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Field\BaseFieldDefinition;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Component\Serialization\Yaml;
use Drupal\Component\Utility\Unicode;
use Drupal\Component\Utility\Xss;
use Drupal\node\NodeInterface;
use League\CommonMark\Environment\Environment;
use League\CommonMark\Extension\HeadingPermalink\HeadingPermalinkExtension;
use League\CommonMark\Extension\ExternalLink\ExternalLinkExtension;

/**
 * Implements hook_theme().
 */
function ood_software_theme() {
  $people_grid = function ($block_class) {
    return [
      'variables' => [
        'items' => [],
        'empty_message' => NULL,
        'scrollable' => TRUE,
        'block_class' => $block_class,
      ],
      'template' => 'people-grid-block',
    ];
  };

  return [
    'appverse_contributors_block' => $people_grid('contributors-block'),
    'discourse_participants_block' => $people_grid('discourse-participants-block'),
    'committee_members_block' => $people_grid('committee-members-block'),
    'ag_coordinators_block' => $people_grid('ag-coordinators-block'),
    'good_conference_committee_block' => $people_grid('good-committee-block'),
    'tips_tricks_calls_block' => $people_grid('tips-tricks-block'),
  ];
}

/**
 * Implements hook_entity_bundle_field_info().
 */
function ood_software_entity_bundle_field_info(EntityTypeInterface $entity_type, $bundle, array $base_field_definitions) {
  $fields = [];

  if ($entity_type->id() === 'node' && $bundle === 'appverse_app') {
    $fields['flag_count'] = BaseFieldDefinition::create('integer')
      ->setLabel(t('Flag Count'))
      ->setDescription(t('Number of users who have flagged this app.'))
      ->setComputed(TRUE)
      ->setClass('\Drupal\ood_software\Field\FlagCountFieldItemList')
      ->setReadOnly(TRUE);
  }

  return $fields;
}

/**
 * Implements hook_form_alter().
 */
function ood_software_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  // Alter the node edit form for 'add software' content type.
  if ($form_id === 'node_appverse_software_edit_form' || $form_id === 'node_appverse_software_form') {
    $form['title']['widget'][0]['value']['#placeholder'] = t('Add title');
    $form['body']['widget'][0]['#placeholder'] = t('Add description');
    $form['field_appverse_software_doc']['widget'][0]['uri']['#placeholder'] = t('Add URL');
    $form['field_appverse_software_website']['widget'][0]['uri']['#placeholder'] = t('Add URL');

    // Adding tags widget.
    $form['field_tags_replace'] = [
      '#type' => 'container',
      '#attributes' => [
        'id' => 'field-tags-replace',
        'data-suggest' => '0',
      ],
      '#weight' => 15,
    ];

    $form['field_tags_replace']['field_suggest'] = [
      '#type' => 'container',
      '#attributes' => [
        'class' => [
          'bg-light-teal',
          'my-5',
          'p-5'
        ]
      ],
    ];

    $form['field_tags_replace']['field_suggest']['tag_list'] = [
      '#markup' => "<div id='match-tag-list' class='mb-3'>Get tag suggestions based on your description and then curate as necessary.</div>",
    ];

    $form['field_tags_replace']['field_suggest']['replace_button'] = [
      '#type' => 'button',
      '#value' => t('Suggest Tags'),
      '#limit_validation_errors' => array(),
      '#attributes' => [
        'class' => [
          'ml-0'
        ],
      ],
      '#ajax' => [
        'callback' => 'ood_software_replace_section_callback',
        'wrapper' => 'field-tags-replace',
      ],
    ];
    $form['field_tags_replace']['user_message'] = [
      '#markup' => "",
    ];


    $add_tags = \Drupal::service('access_misc.addtags');
    $output = $add_tags->getView();
    $tag_label = t('Tags');
    $tag_description = t('Select up to 6 tags that relate to your engagement. Tags will help us find people with related expertise.');
    $tag_summary = t('Select Tags');

    $form['node_add_tags'] = [
      '#markup' => "<div class='font-bold'>$tag_label</div>
        <div class='tag-description'>$tag_description</div>
        <div id='tag-suggestions'></div>
        <details class='tags m-0 mb-8'><summary class='font-bold'>$tag_summary</summary>$output</details>",
      '#weight' => 15,
      '#allowed_tags' => [
        'button',
        'details',
        'summary',
        'div',
        'span',
        'h2',
      ],
    ];

    // Attach javascript.
    $form['#attached']['library'][] = 'access_misc/node_add_tags';
  }
  // Hide the right-sidebar "Revision information" section on appverse_app
  // + appverse_repo node forms. Content for these bundles is
  // sync'd from appverse.yml / manifest.yml; revisions get created
  // automatically by content_moderation, and the request_adjustment
  // flow's comment is stored on those auto-generated revisions —
  // contributors never write revision log messages directly. On the
  // add form especially, the section is the only thing visible in
  // the sidebar and looks like noise.
  // node_appverse_app_form is gone — AddRepoForm at /appverse/add-repo
  // replaces the legacy node-add path, and the
  // LegacyAppAddRedirectSubscriber 301s anyone who hits the old URL.
  $appverseAddForms = [
    'node_appverse_app_edit_form',
    'node_appverse_repo_form',
    'node_appverse_repo_edit_form',
  ];
  if (in_array($form_id, $appverseAddForms, TRUE)) {
    if (isset($form['revision_information'])) {
      $form['revision_information']['#access'] = FALSE;
    }
    // Hide the standalone revision_log textarea too — same rationale.
    if (isset($form['revision_log'])) {
      $form['revision_log']['#access'] = FALSE;
    }
    // Hide the new-revision checkbox.
    if (isset($form['revision'])) {
      $form['revision']['#access'] = FALSE;
    }
  }

  // Edit-form-only alter. The node-add path is gone — AddRepoForm at
  // /appverse/add-repo replaces it, and LegacyAppAddRedirectSubscriber 301s
  // anyone who hits /node/add/appverse_app. The edit-form alter survives
  // unchanged in spirit: library attach, field-access locks for non-admins,
  // intro/footer markup, the read-only field_appverse_repo backref, and
  // formnovalidate on Save.
  if ($form_id === 'node_appverse_app_edit_form') {
    // Attach the CSS library used by the field tweaks below.
    $form['#attached']['library'][] = 'ood_software/appverse_app_form';

    // Get user roles.
    $user = \Drupal::currentUser();
    $roles = $user->getRoles();

    // Hide fields controlled by sync (body, README, last-updated). Sync
    // overwrites these on every refresh; only admins should edit them
    // directly.
    if (!in_array('administrator', $roles)) {
      $form['body']['#access'] = FALSE;
      $form['field_appverse_readme']['#access'] = FALSE;
      $form['field_appverse_lastupdated']['#access'] = FALSE;
    }
    else {
      // Render the lastupdated unix int as a readable date for admins.
      // The field is sync-managed, so an editable int widget isn't useful.
      $node = $form_state->getFormObject()->getEntity();
      $ts = (int) $node->get('field_appverse_lastupdated')->value;
      if ($ts > 0) {
        $form['field_appverse_lastupdated']['widget'][0]['value']['#field_suffix'] =
          ' (' . \Drupal::service('date.formatter')->format($ts, 'medium') . ')';
      }
    }

    $form['intro_text'] = [
      '#type' => 'markup',
      '#markup' => '<div class="mb-4">' . t('See the <strong><a href=":url">contributor documentation</a></strong> for best practices in app integration.', [':url' => '/appverse-contributor-documentation']) . '</div>',
      '#weight' => -10,
    ];

    $form['title']['widget'][0]['value']['#placeholder'] = t('e.g. Docker Version of Abacus');
    $form['field_appverse_github_url']['widget'][0]['uri']['#placeholder'] = t('Add the URL of your repo');
    unset($form['field_appverse_github_url']['widget'][0]['uri']['#description']);

    // Lock field_appverse_repo as a read-only autocomplete. The Repo
    // is set automatically by RepoSyncService when the app is saved with
    // a GitHub URL; manually editing it would be overwritten on the next sync.
    if (isset($form['field_appverse_repo'])) {
      $form['field_appverse_repo']['#disabled'] = TRUE;
      $form['field_appverse_repo']['widget']['#disabled'] = TRUE;
      if (isset($form['field_appverse_repo']['widget'][0])) {
        $form['field_appverse_repo']['widget'][0]['#disabled'] = TRUE;
      }
      if (!isset($form['field_appverse_repo']['widget']['#description'])) {
        $form['field_appverse_repo']['widget']['#description'] = t('Set automatically by sync based on the GitHub repo URL. To change the repo, change the repo URL.');
      }
    }

    // Disable browser HTML5 validation on the Save button. Keeps parity with
    // the legacy alter — Drupal #states[required] doesn't toggle the inner-
    // input required attribute (see [[feedback-drupal-states-quirk]]), and
    // server-side validation still runs.
    if (isset($form['actions']['submit'])) {
      $form['actions']['submit']['#attributes']['formnovalidate'] = 'formnovalidate';
    }

    $form['footer_text'] = [
      '#type' => 'markup',
      '#markup' => '<div class="">' . t('<strong>Thank you for making this available to the community!</strong>') . '</div>',
      '#weight' => 10,
    ];
  }

  // Hide description for link.
  unset($form['field_appverse_license_link']['widget'][0]['uri']['#description']);

  if ($form_id === 'node_appverse_app_edit_form') {
    // Disable the 'field_appverse_github_url' field if the node is published.
    $node = $form_state->getFormObject()->getEntity();
    $user_roles = \Drupal::currentUser()->getRoles();
    if ($node->isPublished() && (!in_array('administrator', $user_roles) && !in_array('appverse_pm', $user_roles))) {
      $form['field_appverse_github_url']['#disabled'] = TRUE;
      $form['field_appverse_github_url']['widget'][0]['uri']['#attributes']['class'][] = 'form-control';
      $form['field_appverse_organization']['#disabled'] = TRUE;
      $form['field_appverse_license_link']['#disabled'] = TRUE;
      $form['field_license']['#disabled'] = TRUE;
    }
  }

}
/**
 * Build the preview block for a Declared Collection.
 *
 * Per-App form fields (Title/Body/AppType/etc.) are hidden client-side
 * via Drupal #states wired in form_alter (watching the
 * appverse_shape_state hidden field). The sync sources those fields
 * from each subpath's manifest.yml at submit time.
 *
 * Returns a Drupal render array — structure carried by #type containers
 * with class hooks, content carried by #markup with escaping applied at
 * the call site. All visual styling lives in css/appverse-app-form.css.
 * No inline style="" anywhere (Drupal's filter system strips style= from
 * #markup, which broke the previous HTML-as-string implementation).
 *
 * The pass-by-reference $form parameter is retained for symmetry with
 * _ood_software_build_single_app_preview, which still mutates $form to
 * pre-populate per-field values.
 */
function _ood_software_build_collection_preview(\Drupal\ood_software\Plugin\GitHubService $gh, array &$form): array {
  $records = $gh->getAppPreviewData();
  $appCount = count($records);
  // Collection-level appverse.yml data. Guard against parse failure —
  // getAppPreviewData() already caught it and returned [], so by the
  // time we get here we know the YAML parses cleanly. Wrap defensively
  // anyway: a corrupted blob between getAppPreviewData and this helper
  // (theoretically impossible in one request) shouldn't WSOD the AJAX.
  try {
    $appverse = Yaml::decode($gh->getAppverseYmlText());
  }
  catch (\Throwable $e) {
    \Drupal::logger('ood_software')->warning('Collection preview: appverse.yml parse failed unexpectedly — @msg', ['@msg' => $e->getMessage()]);
    $appverse = [];
  }
  if (!is_array($appverse)) {
    $appverse = [];
  }

  // Collection-level metadata list. Each entry is a small HTML fragment
  // with user-supplied values escaped at interpolation. We assemble the
  // <ul> as a single #markup string because all items are internally
  // built — no element of $rows comes from outside this function without
  // having been escaped just above.
  $rows = [];
  if (!empty($appverse['maintainer']['name'])) {
    $rows[] = '<strong>' . t('Maintainer:') . '</strong> ' . htmlspecialchars($appverse['maintainer']['name']);
  }
  if (!empty($appverse['maintainer']['support_url'])) {
    $link = _ood_software_safe_link($appverse['maintainer']['support_url']);
    if ($link !== '') {
      $rows[] = '<strong>' . t('Support:') . '</strong> ' . $link;
    }
  }
  if (!empty($appverse['website'])) {
    $link = _ood_software_safe_link($appverse['website']);
    if ($link !== '') {
      $rows[] = '<strong>' . t('Website:') . '</strong> ' . $link;
    }
  }
  if (!empty($appverse['docs'])) {
    $link = _ood_software_safe_link($appverse['docs']);
    if ($link !== '') {
      $rows[] = '<strong>' . t('Docs:') . '</strong> ' . $link;
    }
  }
  if (!empty($appverse['tags']) && is_array($appverse['tags'])) {
    $rows[] = '<strong>' . t('Tags:') . '</strong> ' . htmlspecialchars(implode(', ', $appverse['tags']));
  }
  if (!empty($appverse['shared_paths']) && is_array($appverse['shared_paths'])) {
    $rows[] = '<strong>' . t('Shared paths:') . '</strong> ' . htmlspecialchars(implode(', ', $appverse['shared_paths']));
  }
  $rows[] = '<strong>' . t('Organization:') . '</strong> ' . htmlspecialchars($gh->getOrganization() ?? '');
  $rows[] = '<strong>' . t('Stars:') . '</strong> ' . (int) $gh->getStars();
  $rows[] = '<strong>' . t('License:') . '</strong> ' . htmlspecialchars($gh->getLicense() ?? t('(none detected)'));

  $collectionMetaMarkup = '<h4>' . htmlspecialchars($appverse['title'] ?? '(no title)') . '</h4>';
  if (!empty($appverse['description'])) {
    $collectionMetaMarkup .= '<p>' . htmlspecialchars($appverse['description']) . '</p>';
  }
  $collectionMetaMarkup .= '<ul><li>' . implode('</li><li>', $rows) . '</li></ul>';

  // Build the apps_stack children — one render array per app card.
  $appsStack = [
    '#type' => 'container',
    '#attributes' => ['class' => ['appverse-apps-stack']],
  ];
  if ($appCount === 0) {
    $appsStack['empty'] = [
      '#markup' => '<p><em>' . t('No apps declared in appverse.yml. The repo will register with zero apps.') . '</em></p>',
    ];
  }
  else {
    // Summary line: count apps whose software: declaration didn't resolve
    // to a real Software node. These will save as rejected until the
    // Collection author fixes appverse.yml.
    $unresolved = 0;
    foreach ($records as $r) {
      if (empty($r['software']['resolvedTitle'])) {
        $unresolved++;
      }
    }
    if ($unresolved > 0) {
      $appsStack['unresolved_summary'] = [
        '#markup' => '<p class="appverse-status-warn"><i class="bi bi-exclamation-triangle-fill"></i> '
          . t('@n of @total apps reference Software not in the catalog. These apps will save as <strong>rejected</strong> until appverse.yml is fixed.', ['@n' => $unresolved, '@total' => count($records)])
          . '</p>',
      ];
    }

    foreach ($records as $idx => $r) {
      $appsStack['card_' . $idx] = _ood_software_build_collection_app_card($r);
    }
  }

  return [
    '#type' => 'container',
    '#attributes' => ['class' => ['appverse-preview-frame']],
    'header' => [
      '#markup' => '<p><i class="bi bi-check-lg appverse-status-ok"></i> ' . t('Declared multi-app repo (appverse.yml at root)') . '</p>',
    ],
    'collection_meta' => [
      '#markup' => $collectionMetaMarkup,
    ],
    'apps_heading' => [
      '#markup' => '<h5>' . t('Apps in this repo (@n)', ['@n' => $appCount]) . '</h5>',
    ],
    'apps_stack' => $appsStack,
    'footer_note' => [
      '#markup' => '<p class="text-muted"><em>' . t('Submitting registers the repo and creates @n app(s) via the sync. Per-app metadata is read from each subpath\'s `appverse.yml` (with `manifest.yml` as fallback) — edit those files in the repo to change app data.', ['@n' => $appCount]) . '</em></p>',
    ],
  ];

  // Visibility of per-App form fields is controlled by Drupal #states
  // wired in form_alter; see appverse_shape_state hidden field.
}

/**
 * Build a single card render array for one app inside a Collection preview.
 *
 * Helper for _ood_software_build_collection_preview(); pulled out for
 * readability. Returns a render array structured as: header (subpath +
 * name) → body grid (2x2 of label-above-value cells) → optional
 * description footer. All styling is via class names from
 * css/appverse-app-form.css — no inline style attributes.
 *
 * User-supplied values (subpath, name, declared-software string, tag
 * names, description, role/subcategory) are htmlspecialchars-escaped at
 * the point of interpolation into the #markup strings.
 */
function _ood_software_build_collection_app_card(array $r): array {
  $description = $r['description'] ?? '';
  $roleText = htmlspecialchars($r['role'] ?? '', ENT_QUOTES | ENT_HTML5);
  if (!empty($r['subcategory'])) {
    $roleText .= ' (' . htmlspecialchars($r['subcategory'], ENT_QUOTES | ENT_HTML5) . ')';
  }

  // Software-resolution status from getAppPreviewData()'s per-record
  // 'software' info. Four branches: exact match (green check), fuzzy
  // suggestion (yellow warning), declared but no match (red x),
  // missing key (red x). Static icon HTML is safe to interpolate;
  // user-supplied strings (declared, suggestion) go through
  // htmlspecialchars.
  $softwareInfo = $r['software'] ?? [];
  if (!empty($softwareInfo['resolvedTitle'])) {
    $softwareCell = '<span class="appverse-status-ok"><i class="bi bi-check-lg"></i> '
      . htmlspecialchars($softwareInfo['resolvedTitle'], ENT_QUOTES | ENT_HTML5)
      . '</span>';
  }
  elseif (!empty($softwareInfo['suggestion'])) {
    $softwareCell = '<span class="appverse-status-warn"><i class="bi bi-exclamation-triangle-fill"></i> '
      . t('Unknown: "@d" — did you mean "@s"?', [
        '@d' => $softwareInfo['declared'] ?? '',
        '@s' => $softwareInfo['suggestion'],
      ])
      . '</span>';
  }
  elseif (!empty($softwareInfo['declared'])) {
    $softwareCell = '<span class="appverse-status-err"><i class="bi bi-x-lg"></i> '
      . t('Unknown: "@d"', ['@d' => $softwareInfo['declared']])
      . '</span>';
  }
  else {
    $softwareCell = '<span class="appverse-status-err"><i class="bi bi-x-lg"></i> '
      . t('Missing software: key')
      . '</span>';
  }

  // Tags column. resolveTaxonomyTermsFromAppverseYml returns
  // {declared, resolved, unresolved}. Render resolved as ✅,
  // unresolved with suggestion as ⚠️, unresolved without
  // suggestion as ❌, no declarations as a muted dash.
  $tagsInfo = $r['tags'] ?? ['declared' => [], 'resolved' => [], 'unresolved' => []];
  if (empty($tagsInfo['declared'])) {
    $tagsCell = '<span class="appverse-app-card__value--muted">' . t('—') . '</span>';
  }
  else {
    $parts = [];
    foreach ($tagsInfo['resolved'] as $tag) {
      $parts[] = '<span class="appverse-status-ok"><i class="bi bi-check-lg"></i> '
        . htmlspecialchars($tag['name'], ENT_QUOTES | ENT_HTML5)
        . '</span>';
    }
    foreach ($tagsInfo['unresolved'] as $unresolved) {
      if (!empty($unresolved['suggestion'])) {
        $parts[] = '<span class="appverse-status-warn"><i class="bi bi-exclamation-triangle-fill"></i> '
          . t('"@d" — did you mean "@s"?', [
            '@d' => $unresolved['declared'],
            '@s' => $unresolved['suggestion'],
          ])
          . '</span>';
      }
      else {
        $parts[] = '<span class="appverse-status-err"><i class="bi bi-x-lg"></i> '
          . t('Unknown: "@d"', ['@d' => $unresolved['declared']])
          . '</span>';
      }
    }
    $tagsCell = '<span class="appverse-status-list">' . implode('', $parts) . '</span>';
  }

  $readmeText = !empty($r['readmePresent'])
    ? round(($r['readmeBytes'] ?? 0) / 1024, 1) . ' KB'
    : '—';
  $readmeCellHtml = $readmeText !== '—'
    ? htmlspecialchars($readmeText)
    : '<span class="appverse-app-card__value--muted">—</span>';
  $roleCellHtml = $roleText !== ''
    ? $roleText
    : '<span class="appverse-app-card__value--muted">—</span>';

  $card = [
    '#type' => 'container',
    '#attributes' => ['class' => ['appverse-app-card']],
    'header' => [
      '#type' => 'container',
      '#attributes' => ['class' => ['appverse-app-card__header']],
      'subpath' => [
        '#markup' => '<span class="appverse-app-card__subpath">'
          . htmlspecialchars($r['subpath'] ?? '', ENT_QUOTES | ENT_HTML5)
          . '</span>',
      ],
      'name' => [
        '#markup' => '<span class="appverse-app-card__name">'
          . htmlspecialchars($r['name'] ?? '(none)', ENT_QUOTES | ENT_HTML5)
          . '</span>',
      ],
    ],
    'body' => [
      '#type' => 'container',
      '#attributes' => ['class' => ['appverse-app-card__body']],
      'software_cell' => [
        '#type' => 'container',
        '#attributes' => ['class' => ['appverse-app-card__cell']],
        'label' => ['#markup' => '<div class="appverse-app-card__label">' . t('Software') . '</div>'],
        'value' => ['#markup' => '<div>' . $softwareCell . '</div>'],
      ],
      'tags_cell' => [
        '#type' => 'container',
        '#attributes' => ['class' => ['appverse-app-card__cell']],
        'label' => ['#markup' => '<div class="appverse-app-card__label">' . t('Tags') . '</div>'],
        'value' => ['#markup' => '<div>' . $tagsCell . '</div>'],
      ],
      'role_cell' => [
        '#type' => 'container',
        '#attributes' => ['class' => ['appverse-app-card__cell', 'appverse-app-card__cell--row2']],
        'label' => ['#markup' => '<div class="appverse-app-card__label">' . t('Role') . '</div>'],
        'value' => ['#markup' => '<div>' . $roleCellHtml . '</div>'],
      ],
      'readme_cell' => [
        '#type' => 'container',
        '#attributes' => ['class' => ['appverse-app-card__cell', 'appverse-app-card__cell--row2']],
        'label' => ['#markup' => '<div class="appverse-app-card__label">' . t('README') . '</div>'],
        'value' => ['#markup' => '<div>' . $readmeCellHtml . '</div>'],
      ],
    ],
  ];

  if (!empty($description)) {
    $card['description'] = [
      '#type' => 'container',
      '#attributes' => ['class' => ['appverse-app-card__description']],
      'text' => [
        '#markup' => htmlspecialchars(Unicode::truncate($description, 200, FALSE, TRUE), ENT_QUOTES | ENT_HTML5),
      ],
    ];
  }

  return $card;
}

/**
 * Build the preview block for a Single-App Inferred Collection.
 *
 * This is also where the existing form-field pre-population happens
 * (title, body, license, app types, organization). The form fields
 * remain editable so editors can override before submit — preserves
 * the pre-Phase-1 behavior for apps that haven't yet adopted
 * appverse.yml.
 *
 * Returns a Drupal render array (see notes on the Collection variant).
 */
function _ood_software_build_single_app_preview(\Drupal\ood_software\Plugin\GitHubService $gh, array &$form): array {
  $records = $gh->getAppPreviewData();
  $r = $records[0] ?? [];

  $rows = [];
  if (!empty($r['name'])) {
    $rows[] = '<strong>' . t('Name:') . '</strong> ' . htmlspecialchars($r['name']);
  }
  if (!empty($r['role'])) {
    $rows[] = '<strong>' . t('Role:') . '</strong> ' . htmlspecialchars($r['role']) . (!empty($r['subcategory']) ? ' (' . htmlspecialchars($r['subcategory']) . ')' : '');
  }
  if (!empty($r['description'])) {
    $rows[] = '<strong>' . t('Description:') . '</strong> ' . htmlspecialchars(Unicode::truncate($r['description'], 120, FALSE, TRUE), ENT_QUOTES | ENT_HTML5);
  }
  if (!empty($r['readmePresent'])) {
    $rows[] = '<strong>' . t('README:') . '</strong> ' . round(($r['readmeBytes'] ?? 0) / 1024, 1) . ' KB';
  }
  if (!empty($gh->getLicense())) {
    $rows[] = '<strong>' . t('License:') . '</strong> ' . htmlspecialchars($gh->getLicense());
  }
  $rows[] = '<strong>' . t('Organization:') . '</strong> ' . htmlspecialchars($gh->getOrganization() ?? '');
  $rows[] = '<strong>' . t('Stars:') . '</strong> ' . (int) $gh->getStars();

  // Pre-populate the form fields. Each write is guarded with isset() so this
  // helper can be safely reused from AddRepoForm at /appverse/add-repo, which
  // doesn't have the same widget render tree as the legacy node-add form. On
  // the node-add form all these keys exist, so isset() is a no-op there.
  if (isset($form['body']['widget'])) {
    $form['body']['widget'][0]['value']['#value'] = $gh->getDescription();
  }
  if (isset($form['field_appverse_readme']['widget'])) {
    $form['field_appverse_readme']['widget'][0]['value']['#value'] = $gh->getReadme();
  }
  if (isset($form['title']['widget'])) {
    $form['title']['widget'][0]['value']['#value'] = $gh->getRepoName();
  }
  if (isset($form['field_appverse_lastupdated']['widget'])) {
    $form['field_appverse_lastupdated']['widget'][0]['value']['#value'] = $gh->getLastComittedDate();
  }
  if (isset($form['field_appverse_organization']['widget'])) {
    $form['field_appverse_organization']['widget'][0]['target_id']['#value'] = $gh->getOrganization();
  }
  if ($gh->getLicenseLink() && isset($form['field_appverse_license_link']['widget'])) {
    $form['field_appverse_license_link']['widget'][0]['uri']['#value'] = $gh->getLicenseLink();
  }
  if ($gh->getLicense() && isset($form['field_license']['widget'])) {
    $form['field_license']['widget'][0]['target_id']['#value'] = $gh->getLicense();
  }
  // app_type loop already guards per-checkbox with isset(), so it's safe across hosts.
  foreach ($gh->getAppTypeIds() as $apptype_id) {
    if (isset($form['field_appverse_app_type']['widget'][$apptype_id])) {
      $form['field_appverse_app_type']['widget'][$apptype_id]['#checked'] = TRUE;
      $form['field_appverse_app_type']['widget'][$apptype_id]['#value'] = $apptype_id;
    }
  }

  return [
    '#type' => 'container',
    '#attributes' => ['class' => ['appverse-preview-frame']],
    'header' => [
      '#markup' => '<p><i class="bi bi-check-lg appverse-status-ok"></i> '
        . t('Single-app repository (root manifest.yml, no appverse.yml yet)')
        . '</p>',
    ],
    'note' => [
      '#markup' => '<p><em>' . t('We have pre-filled the form below with what we found. You can edit before submitting.') . '</em></p>',
    ],
    'rows' => [
      '#markup' => '<ul><li>' . implode('</li><li>', $rows) . '</li></ul>',
    ],
  ];
}

/**
 * Render an external URL as a safe anchor tag, or empty string if invalid.
 *
 * Only http(s) URLs are linked. Other schemes (javascript:, data:, file:, etc.)
 * are rejected via a strict scheme prefix check and the Url::fromUri()
 * validation that follows.
 */
function _ood_software_safe_link(string $url, ?string $label = NULL): string {
  if ($url === '') {
    return '';
  }
  // Strict scheme allowlist — Url::fromUri() accepts internal: and entity:
  // schemes which we do NOT want here.
  if (!str_starts_with($url, 'https://') && !str_starts_with($url, 'http://')) {
    return '';
  }
  try {
    $safeUrl = \Drupal\Core\Url::fromUri($url, ['absolute' => TRUE])->toString();
  }
  catch (\Throwable $e) {
    return '';
  }
  $display = $label !== NULL ? $label : $url;
  return '<a href="' . htmlspecialchars($safeUrl, ENT_QUOTES | ENT_HTML5) . '" target="_blank" rel="noopener noreferrer">' . htmlspecialchars($display, ENT_QUOTES | ENT_HTML5) . '</a>';
}

/**
 * Ajax callback function to replace the section with '#markup'.
 */
function ood_software_replace_section_callback(array &$form, FormStateInterface $form_state) {
  $raw_data = $form_state->getUserInput();
  $body = $raw_data['body'][0]['value'];
  $body_filter = $body ? Xss::filter($body) : '';
  $suggested_tag_ids = '0';
  $tag_count = count($raw_data['field_tags'] ?? []);
  $tag_limit = 6;
  $tag_amount = $tag_limit - $tag_count;

  if ($tag_amount <= 0) {
    $form['field_tags_replace']['user_message'] = [
      '#markup' => "<div class='match-tag-list bg-blue-200 text-sky-900 my-5 p-5'>
      <strong class='text-sky-900'>You already have 6 tags</strong><br />
      You can remove some tags to get more suggestions.</div>",
    ];
  }
  elseif (strlen($body_filter) >= 100) {
    try {
      $llm = \Drupal::service('access_llm.ai_references_generator');
      $llm->generateTaxonomyPrompt('tags', 1, $body_filter);
      $suggestions = array_slice($llm->taxonomyIdSuggested(), 0, $tag_amount);
      $suggested_tag_ids = implode(', ', $suggestions);
      $form['field_tags_replace']['user_message'] = [
        '#markup' => "",
      ];
    }
    catch (\Throwable $e) {
      $form['field_tags_replace']['user_message'] = [
        '#markup' => "<div class='match-tag-list bg-yellow-200 text-yellow-900 my-5 p-5'>
        <strong class='text-yellow-900'>AI tag suggestions are not available</strong><br />
        Please select tags manually from the list below.</div>",
      ];
    }
  }
  else {
    $form['field_tags_replace']['user_message'] = [
      '#markup' => "<div class='match-tag-list bg-blue-200 text-sky-900 my-5 p-5'>
      <strong class='text-sky-900'>Fill in the description above to get suggested tags.</strong><br />
                    Your description must be over 100 characters to get a suggestion.</div>",
    ];
  }

  $form['field_tags_replace']['#attributes']['data-suggest'] = $suggested_tag_ids ;

  // Return the updated section.
  return $form['field_tags_replace'];
}

function _ood_software_batch_sync_app(int $collectionId, string $subpath, string $repoUrl, array $repoMetadata, array $parsedRootYml, &$context) {
  try {
    $collection = \Drupal::entityTypeManager()->getStorage('node')->load($collectionId);
    if (!$collection) {
      $context['results']['failed'][$subpath] = 'Collection node disappeared during batch';
      return;
    }

    /** @var \Drupal\ood_software\Plugin\GitHubService $gh */
    $gh = \Drupal::service('ood_software.gh');
    $gh->parseUrl($repoUrl);
    $gh->fetchAppSubpaths([$subpath]);
    $subpathFiles = $gh->getAppSubpathFiles();

    /** @var \Drupal\ood_software\Service\RepoSyncService $sync */
    $sync = \Drupal::service('ood_software.repo_sync');

    // Narrow the parsed apps[] to just this subpath so applyDeclaredApps
    // only processes this one. (applyDeclaredApps iterates
    // $parsedRootYml['apps']; we don't want it to re-iterate all apps
    // on every batch operation.)
    $narrowed = $parsedRootYml;
    $narrowed['apps'] = array_values(array_filter(
      $parsedRootYml['apps'] ?? [],
      fn($a) => is_array($a) && ($a['path'] ?? NULL) === $subpath,
    ));

    $sync->applyDeclaredApps(
      $collection,
      $narrowed,
      $subpathFiles,
      $repoUrl,
      $repoMetadata,
      // Skip reconciliation — the narrowed apps[] only contains this
      // subpath, so reconciling against it would mass-delete every
      // other member App. _ood_software_batch_reconcile_apps runs
      // once at the end with the full canonical apps[].
      FALSE,
    );

    $context['results']['synced'][] = $subpath;
    $context['message'] = t('Synced @path', ['@path' => $subpath]);
  }
  catch (\Throwable $e) {
    $context['results']['failed'][$subpath] = $e->getMessage();
    \Drupal::logger('ood_software')->error('Batch sync failed for @path: @msg', [
      '@path' => $subpath,
      '@msg' => $e->getMessage(),
    ]);
  }
}

/**
 * Batch operation: reconcile member Apps against the canonical apps[].
 *
 * Runs after all per-subpath sync ops. Each of those passed a narrowed
 * apps[] containing only its own subpath, so reconciliation was deferred.
 * This op runs with the full canonical apps[] list and deletes any
 * member App whose subpath is no longer declared.
 */
function _ood_software_batch_reconcile_apps(int $collectionId, string $repoUrl, array $parsedRootYml, &$context) {
  try {
    $collection = \Drupal::entityTypeManager()->getStorage('node')->load($collectionId);
    if (!$collection) {
      $context['results']['failed']['__reconcile__'] = 'Collection node disappeared during reconciliation';
      return;
    }

    $declaredSubpaths = [];
    foreach ($parsedRootYml['apps'] ?? [] as $entry) {
      $path = trim((string) ($entry['path'] ?? ''), '/');
      if ($path !== '') {
        $declaredSubpaths[$path] = TRUE;
      }
    }

    /** @var \Drupal\ood_software\Service\RepoSyncService $sync */
    $sync = \Drupal::service('ood_software.repo_sync');
    $sync->reconcileDeclaredApps($collection, $declaredSubpaths, $repoUrl);

    $context['message'] = t('Reconciled apps[] for @title', ['@title' => $collection->label()]);
  }
  catch (\Throwable $e) {
    $context['results']['failed']['__reconcile__'] = $e->getMessage();
    \Drupal::logger('ood_software')->error('Batch reconciliation failed: @msg', ['@msg' => $e->getMessage()]);
  }
}

/**
 * Batch finished callback: render summary of synced + failed apps.
 */
function _ood_software_batch_repo_synced($success, $results, $operations) {
  if (!$success) {
    \Drupal::messenger()->addError(t('Repo sync did not complete cleanly. Check the repo page for partial results.'));
    return;
  }
  $synced = $results['synced'] ?? [];
  $failed = $results['failed'] ?? [];
  if (!empty($synced)) {
    \Drupal::messenger()->addStatus(t('Synced @n app(s): @list', [
      '@n' => count($synced),
      '@list' => implode(', ', $synced),
    ]));
  }
  if (!empty($failed)) {
    $details = [];
    foreach ($failed as $path => $msg) {
      $details[] = $path . ': ' . $msg;
    }
    \Drupal::messenger()->addError(t('@n app(s) failed to sync — @details', [
      '@n' => count($failed),
      '@details' => implode('; ', $details),
    ]));
  }
}

/**
 * Implements hook_node_insert().
 */
function ood_software_node_insert(NodeInterface $node) {
  _ood_software_invalidate_appverse_cache($node);
  if ($node->bundle() === 'appverse_app') {
    $flag_service = \Drupal::service('flag');
    $flag = $flag_service->getFlagById('appverse_apps');
    $account = \Drupal::currentUser();
    if ($flag && $account->id() && !$flag_service->getFlagging($flag, $node, $account)) {
      $flag_service->flag($flag, $node, $account);
    }
    \Drupal::messenger()->addStatus(t("Thanks for your submission! The Appverse team reviews new apps on Fridays. If we have questions, we'll open an issue on your repo"));
  }
}

/**
 * Implements hook_node_update().
 */
function ood_software_node_update(NodeInterface $node) {
  _ood_software_invalidate_appverse_cache($node);

  // Moderation transition notifications. Collections only — App-level
  // transitions intentionally don't fan out so a cascade-publish on N
  // member apps doesn't produce N emails.
  if ($node->bundle() === 'appverse_repo' && $node->hasField('moderation_state')) {
    $previousState = _ood_software_previous_moderation_state($node);
    $extras = [];
    // Pick up the reviewer comment if AppverseHubRequestChangesForm
    // stashed it on the node before save.
    if (!empty($node->_ood_software_review_comment)) {
      $extras['comment'] = $node->_ood_software_review_comment;
    }
    \Drupal::service('ood_software.repo_notifier')
      ->notifyTransition($node, $previousState, $extras);
  }
}

/**
 * Implements hook_node_delete().
 */
function ood_software_node_delete(NodeInterface $node) {
  _ood_software_invalidate_appverse_cache($node);
}

function _ood_software_invalidate_appverse_cache(NodeInterface $node) {
  // Collection inserts/updates must refresh the cache too — the React
  // widget reads `collections[]` from appverse-data.json, and without
  // this entry an admin-created Collection would not appear in the
  // catalog until the next cron run or app touch.
  if (in_array($node->bundle(), ['appverse_software', 'appverse_app', 'appverse_repo'])) {
    // Throttle: skip if cache was generated less than 60 seconds ago.
    $cache_file = 'public://appverse-cache/appverse-data.json';
    if (file_exists($cache_file) && (time() - filemtime($cache_file)) < 60) {
      return;
    }
    \Drupal::service('ood_software.appverse_cache')->generate();
  }
}

/**
 * Resolve the previous moderation_state for a node update.
 *
 * `$node->original` isn't populated on some Drush / migrate save paths;
 * ModerationInformation::getOriginalState() is the reliable fallback.
 * Returns NULL when no workflow is attached or no prior state exists.
 */
function _ood_software_previous_moderation_state(NodeInterface $node): ?string {
  if (isset($node->original) && $node->original instanceof NodeInterface
      && $node->original->hasField('moderation_state')) {
    return $node->original->get('moderation_state')->value;
  }
  $mi = \Drupal::service('content_moderation.moderation_information');
  if (!$mi->getWorkflowForEntity($node)) {
    return NULL;
  }
  $original = $mi->getOriginalState($node);
  return $original ? $original->id() : NULL;
}

/**
 * Implements hook_content_moderation_notification_mail_data_alter().
 *
 * Suppress the contrib `appverse_review_requested` notification when the
 * subject is a Collection. App-bundle transitions still notify via that
 * contrib config; Collection-bundle transitions notify via our
 * RepoNotificationService (see ood_software_node_update).
 */
function ood_software_content_moderation_notification_mail_data_alter(EntityInterface $entity, array &$data) {
  if ($entity->getEntityTypeId() === 'node' && $entity->bundle() === 'appverse_repo') {
    $data['to'] = [];
  }
}

/**
 * Implements hook_mail().
 *
 * Renders moderation transition emails for appverse_repo nodes.
 * Dispatched by RepoNotificationService from ood_software_node_update.
 *
 * The From and site_name come from \Drupal::config('system.site'), which
 * domain_config overlays with per-domain values at runtime — so a
 * transition fired under the OOD domain context uses OOD's overrides;
 * other domains fall back gracefully. We do NOT set $message['from']
 * explicitly — MailManager handles that from system.site.mail.
 */
function ood_software_mail($key, &$message, $params) {
  $site = \Drupal::config('system.site');
  $site_name = $site->get('name');
  $node = $params['node'] ?? NULL;
  if (!$node instanceof NodeInterface) {
    return;
  }
  $title = $node->label();

  switch ($key) {
    case 'ready_for_review':
      $owner = $node->getOwner();
      $owner_name = $owner ? $owner->getDisplayName() : t('Unknown');
      $repo = $node->hasField('field_repo_url') && !$node->get('field_repo_url')->isEmpty()
        ? ($node->get('field_repo_url')->first()->getValue()['uri'] ?? '')
        : '';
      $admin_queue = \Drupal\Core\Url::fromUserInput('/appverse/manage-repos', ['absolute' => TRUE])->toString();
      $message['subject'] = t('[@site] Repo submitted for review: @title', [
        '@site' => $site_name,
        '@title' => $title,
      ]);
      $message['body'][] = t('@owner submitted "@title" for review on @site.', [
        '@owner' => $owner_name,
        '@title' => $title,
        '@site' => $site_name,
      ]);
      if ($repo) {
        $message['body'][] = t('Repository: @repo', ['@repo' => $repo]);
      }
      $message['body'][] = t('Review queue: @url', ['@url' => $admin_queue]);
      break;

    case 'needs_adjustment':
      // Reviewer comment reaches us via two paths:
      //   1. $params['comment'] — primary, set by
      //      AppverseHubRequestChangesForm via the runtime
      //      _ood_software_review_comment property forwarded through
      //      hook_node_update.
      //   2. Fallback — read getRevisionLogMessage() on the latest
      //      revision. Mirrors the hub preprocess (ood.theme) so any
      //      code path that drives the transition with a revision log
      //      message but doesn't set the runtime property still gets
      //      the comment into the email.
      $comment = $params['comment'] ?? '';
      if ($comment === '') {
        $latestVid = \Drupal::entityTypeManager()->getStorage('node')
          ->getLatestRevisionId($node->id());
        if ($latestVid) {
          $latest = \Drupal::entityTypeManager()->getStorage('node')
            ->loadRevision($latestVid);
          if ($latest && $latest->getRevisionLogMessage()) {
            $comment = $latest->getRevisionLogMessage();
          }
        }
      }
      $hub_link = $node->getOwnerId()
        ? \Drupal\Core\Url::fromUserInput('/user/' . $node->getOwnerId() . '/my-appverse', ['absolute' => TRUE])->toString()
        : '';
      $message['subject'] = t('[@site] Changes requested on your Repo: @title', [
        '@site' => $site_name,
        '@title' => $title,
      ]);
      $message['body'][] = t('A reviewer requested changes on your repo "@title" before it can be published on @site.', [
        '@title' => $title,
        '@site' => $site_name,
      ]);
      if ($comment !== '') {
        $message['body'][] = t("Reviewer's note:\n\n@comment", ['@comment' => $comment]);
      }
      if ($hub_link) {
        $message['body'][] = t('Open your maintenance hub to make changes and resubmit: @url', ['@url' => $hub_link]);
      }
      break;

    case 'published':
      // Build the React catalog URL via pathauto alias so the email
      // lands on /appverse/#/collection/<slug> — same shape the hub
      // Twig uses for its "View in catalog" link.
      $catalog_link = _ood_software_repo_catalog_url($node);
      $message['subject'] = t('[@site] Your Repo is published: @title', [
        '@site' => $site_name,
        '@title' => $title,
      ]);
      $message['body'][] = t('Your repo "@title" has been published to the @site catalog.', [
        '@title' => $title,
        '@site' => $site_name,
      ]);
      $message['body'][] = t('View it in the catalog: @url', ['@url' => $catalog_link]);
      break;
  }
}

/**
 * Resolve the public catalog URL for a Collection.
 *
 * Mirrors the hub preprocess (ood.theme) which builds "View in catalog"
 * links the same way: read the pathauto alias for the node and strip
 * everything up to and including an optional "collection/" prefix to
 * derive the slug, then assemble /appverse/#/collection/<slug>. The
 * production pathauto pattern is /collection/[node:title], so the
 * alias typically looks like /collection/my-collection.
 *
 * When no alias resolves (newly-created node before pathauto runs,
 * alias disabled, etc.), getAliasByPath returns the input path; the
 * fallback slug is the nid so the URL still resolves to something
 * meaningful inside the catalog (not the canonical /node/<nid>).
 */
function _ood_software_repo_catalog_url(NodeInterface $node): string {
  $alias = \Drupal::service('path_alias.manager')
    ->getAliasByPath('/node/' . $node->id());
  // Same regex the hub preprocess uses (ood.theme): strip everything up
  // to and including an optional "repo/" prefix.
  $slug = ltrim(preg_replace('#^.*/(repo/)?#', '', $alias), '/');
  if ($slug === '') {
    $slug = (string) $node->id();
  }
  return \Drupal\Core\Url::fromUserInput('/appverse/#/repo/' . $slug, ['absolute' => TRUE])
    ->toString();
}

/**
 * Implements hook_metatags_alter().
 */
function ood_software_metatags_alter(array &$metatags, array &$context) {
  if (!isset($context['entity']) || !$context['entity'] instanceof NodeInterface) {
    return;
  }
  $node = $context['entity'];

  if ($node->bundle() === 'appverse_software') {
    $logo_url = _ood_software_get_logo_url($node);
  }
  elseif ($node->bundle() === 'appverse_app') {
    $software = $node->get('field_appverse_software_implemen')->entity;
    $logo_url = $software ? _ood_software_get_logo_url($software) : NULL;
  }
  else {
    return;
  }

  if ($logo_url) {
    $metatags['og_image'] = $logo_url;
    $metatags['og_image_url'] = $logo_url;
  }
}

/**
 * Resolves the logo file URL from an appverse_software node.
 */
function _ood_software_get_logo_url(NodeInterface $software_node) {
  if (!$software_node->hasField('field_appverse_logo') || $software_node->get('field_appverse_logo')->isEmpty()) {
    return NULL;
  }
  $media = $software_node->get('field_appverse_logo')->entity;
  if (!$media) {
    return NULL;
  }
  $source_field = $media->getSource()->getConfiguration()['source_field'];
  if (!$media->hasField($source_field) || $media->get($source_field)->isEmpty()) {
    return NULL;
  }
  $file = $media->get($source_field)->entity;
  return $file ? \Drupal::service('file_url_generator')->generateAbsoluteString($file->getFileUri()) : NULL;
}

/**
 * Implements hook_markdown_easy_config_modify().
 */
function ood_software_markdown_easy_config_modify(array &$config) {
  $config['heading_permalink'] = [
    'min_heading_level' => 2,
    'max_heading_level' => 4,
    'insert' => 'none',
    'apply_id_to_heading' => TRUE,
    'id_prefix' => '',
    'fragment_prefix' => '',
  ];
  $config['external_link'] = [
    'internal_hosts' => ['openondemand.connectci.org'],
    'open_in_new_window' => TRUE,
    'nofollow' => 'external',
    'noopener' => 'external',
    'noreferrer' => 'external',
  ];
}

/**
 * Implements hook_markdown_easy_environment_modify().
 */
function ood_software_markdown_easy_environment_modify(Environment &$environment) {
  $environment->addExtension(new HeadingPermalinkExtension());
  $environment->addExtension(new ExternalLinkExtension());
}

/**
 * Implements hook_node_view().
 *
 * - Attaches appverse-docs CSS library and GitHub edit link to synced doc pages.
 * - Redirects browser visitors from appverse node pages to the SPA.
 */
function ood_software_node_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  if ($view_mode !== 'full' || !$entity instanceof NodeInterface) {
    return;
  }

  // Collection node page: list member apps with links to their canonical
  // node pages. Catalog pages can't show unpublished apps (JSON:API filters
  // by status), so this is the path contributors and reviewers use to
  // inspect a draft Collection's members.
  if ($entity->bundle() === 'appverse_repo') {
    $app_storage = \Drupal::entityTypeManager()->getStorage('node');
    $app_ids = $app_storage->getQuery()
      ->accessCheck(TRUE)
      ->condition('type', 'appverse_app')
      ->condition('field_appverse_repo', $entity->id())
      ->sort('field_appverse_app_subpath')
      ->execute();

    if ($app_ids) {
      $items = [];
      foreach ($app_storage->loadMultiple($app_ids) as $app) {
        $subpath = $app->hasField('field_appverse_app_subpath')
          && !$app->get('field_appverse_app_subpath')->isEmpty()
            ? $app->get('field_appverse_app_subpath')->value
            : '';
        $items[] = [
          '#type' => 'link',
          '#title' => $subpath
            ? t('@title (@subpath)', ['@title' => $app->label(), '@subpath' => $subpath])
            : $app->label(),
          '#url' => $app->toUrl(),
        ];
      }
      $build['member_apps'] = [
        '#type' => 'fieldset',
        '#title' => t('Apps in this repo'),
        '#weight' => 20,
        'list' => [
          '#theme' => 'item_list',
          '#items' => $items,
        ],
      ];
    }
  }

  // Appverse documentation pages: attach CSS and GitHub edit link.
  $doc_map = array_flip(\Drupal\ood_software\Service\DocSyncService::DOC_MAP);
  $nid = (int) $entity->id();
  if (isset($doc_map[$nid])) {
    $build['#attached']['library'][] = 'ood_software/appverse-docs';

    $github_url = 'https://github.com/sweet-and-fizzy/ood-appverse/edit/main/docs/' . $doc_map[$nid];
    $build['github_edit_link'] = [
      '#type' => 'container',
      '#attributes' => ['class' => ['appverse-docs-github-link']],
      '#weight' => -100,
      'link' => [
        '#type' => 'link',
        '#title' => 'Suggest an edit on GitHub',
        '#url' => \Drupal\Core\Url::fromUri($github_url),
        '#attributes' => ['target' => '_blank', 'rel' => 'noopener'],
      ],
    ];
  }

  // Appverse SPA redirects for software and app nodes. Only for published
  // nodes — the React catalog reads via JSON:API which filters by
  // status=1, so redirecting an unpublished node into the catalog yields
  // a "not found" page. Contributors and admins viewing a draft need the
  // Drupal canonical node view instead.
  if ($entity->bundle() === 'appverse_software' && $entity->isPublished()) {
    $slug = basename($entity->toUrl()->toString());
    $build['#attached']['html_head'][] = [
      [
        '#type' => 'html_tag',
        '#tag' => 'script',
        '#value' => "window.location.replace('/appverse#/' + " . json_encode($slug) . ");",
      ],
      'appverse_redirect',
    ];
  }
  elseif ($entity->bundle() === 'appverse_app' && $entity->isPublished()) {
    $software = $entity->get('field_appverse_software_implemen')->entity;
    if ($software) {
      $software_slug = basename($software->toUrl()->toString());
      $app_slug = basename($entity->toUrl()->toString());
      $build['#attached']['html_head'][] = [
        [
          '#type' => 'html_tag',
          '#tag' => 'script',
          '#value' => "window.location.replace('/appverse#/' + " . json_encode($software_slug) . " + '?app=' + " . json_encode($app_slug) . ");",
        ],
        'appverse_redirect',
      ];
    }
  }
}

/**
 * Implements hook_menu_local_tasks_alter().
 *
 * Push the "Revisions" tab to the END of the tab strip on
 * appverse_repo and appverse_app node pages. Content for these
 * bundles is derived from appverse.yml / manifest.yml in the source
 * repo; each sync overwrites the same fields, so revision history is
 * rarely meaningful to contributors. Keeping the tab available for
 * admins who need it, but visually deprioritized.
 *
 * Revisions are still created on save — content_moderation requires
 * them, and the request_adjustment flow stores the admin's comment
 * as the revision log message.
 */
function ood_software_menu_local_tasks_alter(&$data, $route_name, \Drupal\Core\Cache\RefinableCacheableDependencyInterface &$cacheability) {
  if ($route_name !== 'entity.node.canonical' && $route_name !== 'entity.node.version_history') {
    return;
  }
  $node = \Drupal::routeMatch()->getParameter('node');
  if (!$node instanceof \Drupal\node\NodeInterface) {
    return;
  }
  if (!in_array($node->bundle(), ['appverse_app', 'appverse_repo'], TRUE)) {
    return;
  }
  // The tab strip is cached per route + node; bind both so a
  // bundle-change (unlikely but possible) invalidates it.
  $cacheability->addCacheableDependency($node);
  foreach ($data['tabs'] as $level => $tabs) {
    foreach ($tabs as $key => $tab) {
      if (isset($tab['#link']['url']) && $tab['#link']['url']->isRouted()) {
        if ($tab['#link']['url']->getRouteName() === 'entity.node.version_history') {
          // Bump the weight so it sorts to the end. Drupal core's
          // default tab weights are 0..10; 100 reliably lands last.
          $data['tabs'][$level][$key]['#weight'] = 100;
        }
      }
    }
  }
}

/**
 * Implements hook_views_pre_render().
 *
 * The per-row preprocess attaches appverse_hub too, but on an empty result
 * set it never runs and the exposed-form filter grid loses its CSS.
 */
function ood_software_views_pre_render(\Drupal\views\ViewExecutable $view) {
  if ($view->id() === 'my_appverse') {
    $view->element['#attached']['library'][] = 'ood_software/appverse_hub';
  }
}

/**
 * Implements hook_views_data_alter().
 *
 * Core's field-storage discovery types appverse_app's
 * field_appverse_software_implemen_target_id as a numeric filter (it's an
 * integer column), so the manage-repos exposed filter renders as a plain
 * number input. Override to the entity_reference filter so it renders as
 * an autocomplete bound to appverse_software titles.
 */
function ood_software_views_data_alter(array &$data) {
  if (isset($data['node__field_appverse_software_implemen']['field_appverse_software_implemen_target_id']['filter'])) {
    $data['node__field_appverse_software_implemen']['field_appverse_software_implemen_target_id']['filter']['id'] = 'entity_reference';
    $data['node__field_appverse_software_implemen']['field_appverse_software_implemen_target_id']['filter']['entity_type'] = 'node';
  }
}

